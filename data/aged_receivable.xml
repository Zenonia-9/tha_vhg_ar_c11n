<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="aged_receivable_report_anzer_id" model="account.report.column">
        <field name="name">Anzer ID</field>
        <field name="expression_label">anzer_id</field>
        <field name="figure_type">string</field>
        <field name="sequence">21</field>
        <field name="report_id" ref="account_reports.aged_receivable_report"/>
    </record>

    <record id="aged_receivable_report_vendor_ref" model="account.report.column">
        <field name="name">Anzer Reference</field>
        <field name="expression_label">vendor_ref</field>
        <field name="figure_type">string</field>
        <field name="sequence">22</field>
        <field name="report_id" ref="account_reports.aged_receivable_report"/>
    </record>

    <record id="aged_receivable_report_invoice_no" model="account.report.column">
        <field name="name">Invoice No.</field>
        <field name="expression_label">invoice_no</field>
        <field name="figure_type">string</field>
        <field name="sequence">23</field>
        <field name="report_id" ref="account_reports.aged_receivable_report"/>
    </record>

    <record id="aged_receivable_report_ref" model="account.report.column">
        <field name="name">Reference</field>
        <field name="expression_label">ref</field>
        <field name="figure_type">string</field>
        <field name="sequence">24</field>
        <field name="report_id" ref="account_reports.aged_receivable_report"/>
    </record>

    <record id="aged_receivable_line_anzer_id" model="account.report.expression">
        <field name="label">anzer_id</field>
        <field name="engine">custom</field>
        <field name="formula">_report_custom_engine_aged_receivable</field>
        <field name="subformula">anzer_id</field>
        <field name="auditable" eval="False"/>
        <field name="report_line_id" ref="account_reports.aged_receivable_line"/>
    </record>

    <record id="aged_receivable_line_vendor_ref" model="account.report.expression">
        <field name="label">vendor_ref</field>
        <field name="engine">custom</field>
        <field name="formula">_report_custom_engine_aged_receivable</field>
        <field name="subformula">vendor_ref</field>
        <field name="auditable" eval="False"/>
        <field name="report_line_id" ref="account_reports.aged_receivable_line"/>
    </record>

    <record id="aged_receivable_line_invoice_no" model="account.report.expression">
        <field name="label">invoice_no</field>
        <field name="engine">custom</field>
        <field name="formula">_report_custom_engine_aged_receivable</field>
        <field name="subformula">invoice_no</field>
        <field name="auditable" eval="False"/>
        <field name="report_line_id" ref="account_reports.aged_receivable_line"/>
    </record>

    <record id="aged_receivable_line_ref" model="account.report.expression">
        <field name="label">ref</field>
        <field name="engine">custom</field>
        <field name="formula">_report_custom_engine_aged_receivable</field>
        <field name="subformula">ref</field>
        <field name="auditable" eval="False"/>
        <field name="report_line_id" ref="account_reports.aged_receivable_line"/>
    </record>
</odoo>
